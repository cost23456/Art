  m_Script: {fileID: 11500000, guid: e8df9321fbc092e4bb390a4c8b134801, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  ForeGame: {fileID: 8300000, guid: ed2eb31b5027dd049bb9607c8656f212, type: 3}
  DialogClip: {fileID: 8300000, guid: aee5543f94c80724687ab61967dff3ce, type: 3}
  BGMClip: {fileID: 8300000, guid: b729ca2064e3c0c4d8d10cb7eabb94bd, type: 3}
  Group1:
  - {fileID: 5464742089421770618}
  - {fileID: 4268946364583487587}
  - {fileID: 3771291514660368329}
  - {fileID: 788650245612640949}
  Group2:
  - {fileID: 5447571910367375255}
  - {fileID: 4137621739605032230}
  - {fileID: 5964535670745575183}
  - {fileID: 3975323562746219065}
  Texts1:
  - {fileID: 5090380489330263265}
  - {fileID: 3648743806520099271}
  - {fileID: 4116644817288628613}
  - {fileID: 1906189173897041667}
  Texts2:
  - {fileID: 201945761876564069}
  - {fileID: 3069273433975965507}
  - {fileID: 7519977737342176306}
  - {fileID: 2682681290410439664}
  Dialog1:
  - "\u5317\u5B8B\u7687\u7950\u4E94\u5E74\uFF0C\u6CC9\u5DDE\u3002 "
  - "\u4E07\u5B89\u6E21\u53E3\uFF0C\u6C5F\u9614\u4E94\u91CC\uFF0C\u98CE\u6D9B\u6C79\u6D8C\u3002\u6BCF\u9047\u6F6E\u72C2\u98CE\u6025\uFF0C\u6E21\u8239\u503E\u8986\uFF0C\u846C\u8EAB\u9C7C\u8179\u8005\uFF0C\u5C81\u6709\u6570\u5341\u3002\u5546\u65C5\u88F9\u8DB3\uFF0C\u767E\u59D3\u671B\u6D0B\u5174\u53F9\uFF0C\u6B64\u6E21\u5DF2\u6210\u6CC9\u4EBA\u4E4B\u754F\u9014\u3002 "
  - "\u7687\u7950\u4E94\u5E74\uFF0C\u90E1\u5B88\u8521\u8944\u4F53\u5BDF\u6C11\u763C\uFF0C\u51B3\u610F\u5728\u6B64\u5929\u5811\u4E4B\u4E0A\uFF0C\u5792\u77F3\u4E3A\u6865\u3002\u7136\u800C\u6C5F\u6D41\u6E4D\u6025\uFF0C\u6D77\u5E95\u6DE4\u6CE5\u6DF1\u4E0D\u53EF\u6D4B\uFF0C\u524D\u4EBA\u6570\u6B21\u5C1D\u8BD5\uFF0C\u7686\u4EE5\u6869\u6728\u5C3D\u6298\u3001\u77F3\u57FA\u6C89\u6CA1\u544A\u7EC8\u3002 "
  - "\u65F6\u4EBA\u7686\u8A00\uFF1A\u975E\u4EBA\u529B\u53EF\u4E3A\u3002 "
  ShowTime1:
  - 2
  - 14.5
  - 14
  - 6
  Dialog2:
  - "\u4F60\u8E72\u5728\u6D1B\u9633\u6865\u6865\u58A9\u65C1\uFF0C\u819D\u4E0A\u94FA\u7740\u6D4B\u7ED8\u677F\uFF0C\u63E1\u7B14\u5728\u786B\u9178\u7EB8\u4E0A\u52FE\u52D2\u6865\u58A9\u5256\u9762\uFF0C\u7EC6\u81F4\u8BB0\u5F55\u71D5\u5C3E\u69AB\u94C1\u4EF6\u7684\u5D4C\u5408\u7ED3\u6784\uFF0C\u8FD9\u662F\u4F60\u8BBA\u6587\u7B2C\u4E09\u7AE0\u7684\u6838\u5FC3\u6570\u636E\u3002"
  - "\u4F60\u5DF2\u5728\u6CC9\u5DDE\u9A7B\u7559\u4E09\u65E5\uFF0C\u6BCF\u65E5\u65E9\u51FA\u665A\u5F52\uFF0C\u5C06\u4E07\u5B89\u6865\u5185\u5916\u7ED3\u6784\u7EC6\u81F4\u52D8\u6D4B\u5B8C\u6BD5\u3002\u5BFC\u5E08\u4E24\u6B21\u5FAE\u4FE1\u50AC\u4FC3\u8FD4\u6821\u6539\u8BBA\u6587\uFF0C\u4F60\u53EA\u56DE\u590D\u9700\u518D\u8865\u4E00\u7EC4\u6570\u636E\uFF0C\u4FBF\u4E13\u5FC3\u6295\u5165\u6D4B\u7ED8\u3002"
  - "\u6865\u9762\u6E38\u4EBA\u7199\u6518\uFF0C\u5BFC\u6E38\u8BB2\u89E3\u7740\u8521\u8944\u4E0E\u4E07\u5B89\u6865\u7684\u5386\u53F2\uFF0C\u8FD9\u4E9B\u53F2\u6599\u4F60\u65E9\u5DF2\u719F\u8BFB\uFF0C\u6B64\u523B\u53EA\u4E13\u6CE8\u5206\u8FA8\u77F3\u6750\uFF1A\u5B8B\u4EE3\u539F\u6784\u3001\u6E05\u4EE3\u4FEE\u8865\u3001\u73B0\u4EE3\u4FEE\u7F2E\u7684\u533A\u522B\uFF0C\u4EE5\u53CA\u77F3\u5757\u4E0A\u5404\u5F02\u7684\u933E\u7EB9\u3002
    \u826F\u4E45\uFF0C\u4F60\u6536\u8D77\u6D4B\u7ED8\u677F\u8D77\u8EAB\u6D3B\u52A8\u50F5\u786C\u8116\u9888\uFF0C\u6070\u9022\u6F6E\u6C34\u4E0A\u6DA8\uFF0C\u6F2B\u5411\u6865\u58A9\u77F3\u57FA\uFF0C\u4F60\u987A\u52BF\u540E\u9000\u907F\u8BA9\u3002\u4E0D\u6599\u811A\u4E0B\u8E29\u5230\u6E7F\u6ED1\u77F3\u5757\uFF0C\u8EAB\u4F53\u9AA4\u7136\u540E\u4EF0\uFF0C\u4F38\u624B\u6293\u6865\u680F\u672A\u679C\uFF0C\u6307\u5C16\u4EC5\u64E6\u8FC7\u7C97\u7CD9\u77F3\u9762\u3002"
  - "\u6700\u7EC8\u4F60\u5760\u5165\u51B0\u51B7\u6F6E\u6C34\uFF0C\u6E10\u6E10\u5931\u53BB\u610F\u8BC6\u3002"
  ShowTime2:
  - 5
  - 5
  - 5
  - 5
